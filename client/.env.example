# ─────────────────────────────────────────────
# Vibe Talk — Client Environment Variables
# Copy this file to .env and fill in real values
# ─────────────────────────────────────────────

# ── API Base URL ─────────────────────────────
# Development:
REACT_APP_API_URL=http://localhost:5000/api
# Production (uncomment and replace the line above):
# REACT_APP_API_URL=https://api.vibetalk.me/api
# — OR if backend is served from the same domain —
# REACT_APP_API_URL=https://vibetalk.me/api

# ── Socket.IO Server URL ─────────────────────
# Development:
REACT_APP_SOCKET_URL=http://localhost:5000
# Production (uncomment and replace the line above):
# REACT_APP_SOCKET_URL=https://api.vibetalk.me
# — OR if backend is served from the same domain —
# REACT_APP_SOCKET_URL=https://vibetalk.me
