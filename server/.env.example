# ─────────────────────────────────────────────
# Vibe Talk — Server Environment Variables
# Copy this file to .env and fill in real values
# ─────────────────────────────────────────────

# ── Server ──────────────────────────────────
# Port the Express/Socket.IO server listens on
PORT=5000

# Allowed client origins (comma-separated for multiple).
# Development:
CLIENT_URL=http://localhost:3000
# Production (uncomment and replace localhost line above):
# CLIENT_URL=https://vibetalk.me,https://www.vibetalk.me

# ── MongoDB ─────────────────────────────────
# Connection string from MongoDB Atlas or local instance
# Example Atlas URI: mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/vibetalk?retryWrites=true&w=majority
MONGO_URI=your_mongodb_uri

# ── JWT ─────────────────────────────────────
# Long random secret — generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_jwt_secret
# Token validity duration (default: 30d).  Examples: 7d, 24h, 60m
JWT_EXPIRY=30d

# ── Cloudinary ──────────────────────────────
# Sign up at https://cloudinary.com — free tier is sufficient for development.
# Find these values in: Cloudinary Dashboard → Settings → API Keys
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret
